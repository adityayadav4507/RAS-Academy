rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Rules for the "users" collection
    match /users/{userId} {
      // Allow users to read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to create their own initial profile as a "free" user
      allow create: if request.auth != null && request.auth.uid == userId 
                    && request.resource.data.subscriptionStatus == 'free' 
                    && request.resource.data.planType == 'free';
      
      // Allow users to update their own notes and completed topics,
      // but prohibit them from modifying key subscription/payment properties.
      allow update: if request.auth != null && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny([
                      'subscriptionStatus', 
                      'planType', 
                      'paymentId', 
                      'orderId', 
                      'paymentSignature', 
                      'paymentTimestamp'
                    ]));
    }
  }
}
