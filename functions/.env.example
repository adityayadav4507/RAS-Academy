# Port for Express Server
PORT=5000

# CORS Allowed Origins (Comma-separated)
# For development, allow localhost. Add your production frontend domain (e.g. https://yourapp.firebaseapp.com)
ALLOWED_ORIGINS=http://localhost:5173

# Razorpay API Credentials
# Replace with your actual credentials from Razorpay Dashboard (Settings -> API Keys)
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# Firebase Admin SDK Configuration
# Option 1: Path to Firebase Service Account JSON (or stringified JSON content)
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'
# Option 2: Individual credentials (recommended for Render)
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=YOUR_FIREBASE_CLIENT_EMAIL
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
